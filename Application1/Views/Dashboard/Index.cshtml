@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Dashboard - Application 1</h2>
        <p class="text-muted mb-0">Xin chào <strong>@User.Identity?.Name</strong></p>
    </div>
    <span class="badge text-bg-primary fs-6">@(User.IsInRole("Admin") ? "Admin" : "User")</span>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100 border-0 bg-light">
            <div class="card-body">
                <h5 class="card-title">Users</h5>
                <p class="card-text text-muted">Quản lý danh sách người dùng và phân quyền.</p>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Users" asp-action="Index" class="btn btn-sm btn-primary">Mở User Management</a>
                }
                else
                {
                    <span class="badge text-bg-secondary">Chỉ dành cho Admin</span>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 bg-light">
            <div class="card-body">
                <h5 class="card-title">Reports</h5>
                <p class="card-text text-muted">Theo dõi báo cáo nghiệp vụ và số liệu hệ thống.</p>
                <a asp-controller="Reports" asp-action="Index" class="btn btn-sm btn-outline-primary">Xem Reports</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 bg-light">
            <div class="card-body">
                <h5 class="card-title">Settings</h5>
                <p class="card-text text-muted">Cấu hình thông tin và tùy chọn ứng dụng.</p>
                <a asp-controller="Settings" asp-action="Index" class="btn btn-sm btn-outline-primary">Mở Settings</a>
            </div>
        </div>
    </div>
</div>
