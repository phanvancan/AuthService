@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Dashboard - Application 2</h2>
        <p class="text-muted mb-0">Xin chào <strong>@User.Identity?.Name</strong></p>
    </div>
    <span class="badge text-bg-primary fs-6">@(User.IsInRole("Admin") ? "Admin" : "User")</span>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100 border-0 bg-light">
            <div class="card-body">
                <h5 class="card-title">Monitoring</h5>
                <p class="card-text text-muted">Theo dõi trạng thái hệ thống theo thời gian thực.</p>
                <a asp-controller="Monitoring" asp-action="Index" class="btn btn-sm btn-outline-primary">Mở Monitoring</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 bg-light">
            <div class="card-body">
                <h5 class="card-title">Logs</h5>
                <p class="card-text text-muted">Kiểm tra sự kiện và nhật ký hoạt động.</p>
                <a asp-controller="Logs" asp-action="Index" class="btn btn-sm btn-outline-primary">Xem Logs</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 bg-light">
            <div class="card-body">
                <h5 class="card-title">Settings</h5>
                <p class="card-text text-muted">Quản trị cấu hình và tùy chọn ứng dụng.</p>
                <a asp-controller="Settings" asp-action="Index" class="btn btn-sm btn-outline-primary">Mở Settings</a>
            </div>
        </div>
    </div>
</div>
