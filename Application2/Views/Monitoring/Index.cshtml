@{
    ViewData["Title"] = "Monitoring";
}

<h2 class="mb-3">Monitoring</h2>
<p class="text-muted">Giám sát tài nguyên và dịch vụ tích hợp.</p>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card border-0 bg-light">
            <div class="card-body">
                <h6 class="text-muted mb-2">AuthService</h6>
                <span class="badge text-bg-success">Healthy</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 bg-light">
            <div class="card-body">
                <h6 class="text-muted mb-2">Database</h6>
                <span class="badge text-bg-success">Connected</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 bg-light">
            <div class="card-body">
                <h6 class="text-muted mb-2">Latency</h6>
                <span class="badge text-bg-primary">42 ms</span>
            </div>
        </div>
    </div>
</div>
